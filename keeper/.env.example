# -- Server --
PORT=3001
NODE_ENV=production
API_SECRET=your_api_secret_here

# -- Stellar -- MAINNET --
STELLAR_NETWORK=mainnet
STELLAR_RPC_URL=https://mainnet.stellar.org/soroban/rpc
STELLAR_HORIZON_URL=https://horizon.stellar.org
STELLAR_NETWORK_PASSPHRASE=Public Global Stellar Network ; September 2015

# -- Keeper Keypair --
KEEPER_PUBLIC_KEY=your_keeper_public_key_here
KEEPER_SECRET_KEY=your_keeper_secret_key_here

# -- Contracts -- MAINNET ADDRESSES (update after deployment) --
VAULT_CONTRACT_ID=<MAINNET_VAULT_CONTRACT_ID>
AMM_CONTRACT_ID=<MAINNET_AMM_CONTRACT_ID>

# -- Supabase --
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# -- Telegram --
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your_telegram_webhook_secret_here

# -- External APIs --
AQUARIUS_API_URL=https://api.aqua.network/api/v1

# -- Cron --
WATCHDOG_INTERVAL_MINUTES=30
COMPOUND_INTERVAL_HOURS=4
RED_ALERT_THRESHOLD=3

# -- CORS --
FRONTEND_URL=https://frontend-beta-rouge-rgheunscve.vercel.app
